{
  "openapi": "3.1.0",
  "info": {
    "title": "Korean Stock Quick Study API",
    "description": "한국 주식 종목명을 받아 주가, DART 재무, CompanyGuide Financial Highlight 컨센서스 데이터를 반환합니다.",
    "version": "1.6.0"
  },
  "servers": [
    {
      "url": "https://stock-quick-study-api.onrender.com"
    }
  ],
  "paths": {
    "/stock-report": {
      "get": {
        "operationId": "getStockReport",
        "summary": "한국 주식 퀵 스터디 데이터 조회",
        "description": "종목명을 입력하면 주가, 시가총액, DART 재무, CompanyGuide/FnGuide 컨센서스 데이터를 조회합니다.",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "description": "한국 주식 종목명. 예: 삼천당제약",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "종목 퀵 스터디 데이터",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "input": {
                      "type": "string"
                    },
                    "resolved": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "data_basis": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "price": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "weekly_price_summary": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "historical_financials": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "latest_regular_report": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "consensus": {
                      "type": "object",
                      "additionalProperties": true
                    },
                    "recent_news": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    },
                    "dcinside_community": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}