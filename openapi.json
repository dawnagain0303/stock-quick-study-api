{
  "openapi": "3.1.0",
  "info": {
    "title": "Korean Stock Quick Study API",
    "version": "3.5.0",
    "description": "한국 주식 종목 데이터를 반환합니다. 디시를 제외하고 네이버 뉴스 30일 및 네이버 블로그 30일 검색 결과를 제공합니다."
  },
  "servers": [
    {
      "url": "https://stock-quick-study-api.onrender.com"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/stock-report": {
      "get": {
        "operationId": "getStockReport",
        "summary": "한국 주식 퀵 스터디 데이터 조회",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "종목명 예: 삼성전자"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/getStockReport": {
      "get": {
        "operationId": "getStockReportAlias",
        "summary": "한국 주식 퀵 스터디 데이터 조회 GET 호환",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "getStockReportPost",
        "summary": "한국 주식 퀵 스터디 데이터 조회 POST 호환",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/blog-reaction": {
      "get": {
        "operationId": "getBlogReaction",
        "summary": "네이버 블로그 30일 반응 조회",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "종목명 예: 삼성전자"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    }
  }
}